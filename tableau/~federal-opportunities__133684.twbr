        <column caption='NAICS  Code' datatype='string' name='[Calculation_9186708136599552]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='IF ISNULL([NAICS_CODE]) THEN &quot;Unknown NAICS&quot;&#13;&#10;   ELSE STR([NAICS_CODE]) + &quot; - &quot; + [NAICS_DESCRIPTION]&#13;&#10;   END' />
        </column>
        <column caption='PSC' datatype='string' name='[Calculation_9186708137447425]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='IF ISNULL([PSC_CODE]) THEN &quot;No PSC Code&quot;&#13;&#10;ELSE STR([PSC_CODE]) + &quot; - &quot; + [PSC_NAME]&#13;&#10;END' />
        </column>
        <column caption='NAICS Sector' datatype='string' name='[Calculation_9186708138074114]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='IF ISNULL([SECTOR_CODE]) THEN &quot;Unknown Sector&quot;&#13;&#10;ELSE STR([SECTOR_CODE]) + &quot; - &quot; + [SECTOR_NAME]&#13;&#10;END' />
        </column>
        <column caption='PSC Category' datatype='string' name='[Calculation_9186708139151363]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='IF ISNULL([PSC_CODE]) THEN &quot;No Category&quot;&#13;&#10;ELSEIF LEFT(STR([PSC_CODE]), 1) &gt;= &apos;A&apos; AND LEFT(STR([PSC_CODE]), 1) &lt;= &apos;Z&apos;&#13;&#10;    THEN LEFT(STR([PSC_CODE]), 1) + &quot; - &quot; + [PSC_CATEGORY]&#13;&#10;ELSE [PSC_CATEGORY]&#13;&#10;END' />
        </column>
